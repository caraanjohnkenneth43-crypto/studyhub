# StudyHub — Environment Variables
# Copy this to .env.local and fill in the values.
# .env.local is gitignored — keep secrets out of the repo.

# ─── Admin SDK (required for API routes) ──────────────────────
# Full Firebase service account JSON, single line with \n escapes.
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=

# Fallback split creds (not recommended — may fail with "Could not load default credentials")
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_PROJECT_ID=studyhub-e1f30
